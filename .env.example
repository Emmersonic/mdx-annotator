# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Linear team email-to-issue intake address
# Linear: Settings → Teams → [Team] → Integrations → Email
LINEAR_INTAKE_EMAIL=team-xyz@linear.app

# Verified Resend sender (must be on a verified domain)
RESEND_FROM=reviews@yourdomain.com
